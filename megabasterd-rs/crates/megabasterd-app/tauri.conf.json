{
  "productName": "MegaBasterd",
  "version": "1.0.0",
  "identifier": "com.megabasterd.app",
  "build": {
    "frontendDist": "megabasterd-app/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix megabasterd-app/frontend",
    "beforeBuildCommand": "npm run build --prefix megabasterd-app/frontend"
  },
  "app": {
    "windows": [
      {
        "title": "MegaBasterd",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
